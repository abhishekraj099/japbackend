generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PREMIUM
}

// Provider telemetry (Phase 25I.2). Pre-aggregated daily counters keyed by
// (date, platform, event) — NOT raw events and NOT tied to any user → minimal
// storage (≤ ~65 rows/day) and zero PII. Independent of study/review/cards.
model TelemetryDaily {
  id        String   @id @default(cuid())
  date      String // server date, YYYY-MM-DD
  platform  String // youtube | netflix | viki | ai | other
  event     String // provider_matched | cue_extracted | ...
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([date, platform, event])
  @@index([date])
  @@map("telemetry_daily")
}

// Synthetic provider monitoring (Phase 25I.3). One row per health-check run per
// provider (daily / CI). Independent of real-user telemetry. Tiny footprint.
model ProviderHealthCheck {
  id           String   @id @default(cuid())
  provider     String // youtube | netflix | viki
  healthy      Boolean
  checksPassed Int
  checksFailed Int
  createdAt    DateTime @default(now())

  @@index([provider, createdAt])
  @@map("provider_health_checks")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String

  // Subscription plan (Phase 26B). Drives AI daily quota; no billing yet.
  plan         Plan     @default(FREE)

  decks        Deck[]
  integrations Integration[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// External integration connections (e.g. Anki, future cloud storage). Provider
// is a free-form string and there are NO provider-specific columns, so new
// providers (google_drive, dropbox, …) need no schema change. One row per
// (user, provider). This phase only tracks connection status — no sync.
model Integration {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider  String   // "anki" | "google_drive" | "dropbox" | …
  status    String   @default("connected") // "connected" | "disconnected"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

model Deck {
  id          String   @id @default(cuid())
  name        String
  description String?
  language    String   @default("ja")

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  cards       Card[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("decks")
}

model Card {
  id              String        @id @default(cuid())

  // Discriminator for single-table inheritance: "vocab" | "grammar".
  // Keeps grammar + vocabulary cards in one table so a future unified review
  // is a single query over cards/card_schedules with FSRS scheduling intact.
  cardType        String        @default("vocab")

  question        String
  answer          String
  tags            String[]      @default([])

  reading         String?
  meaning         String?
  grammarNotes    String?
  jlptLevel       String?
  frequency       Int?

  // Optional pitch-accent metadata for vocabulary cards, e.g. "①" / "②".
  // Null for grammar/sentence cards and when no data is available.
  pitchAccent     String?

  // Grammar-card fields (null/empty for vocabulary cards).
  patternId       String?       // grammar pattern id, e.g. "te-iru" — dedup key
  examples        String[]      @default([])

  sourceType      String?
  sourceUrl       String?
  contextSentence String?

  // Combined-card fields (Phase 18C): an example sentence attached to a
  // vocabulary card. A render mode, NOT a new cardType — null for plain cards.
  exampleSentence    String?
  exampleReading     String?
  exampleTranslation String?
  pageTitle          String?
  extractionSource   String?  // "ruby" | "page" | "ai"

  // Contextual screenshot for the card (Phase 24): a data URL (JPEG) captured
  // from a video frame or page region at mine time. Optional.
  imageUrl           String?  @db.Text

  // Native audio clip mined from the video (Phase 25D): a data URL (webm/opus)
  // of the spoken subtitle line. Optional.
  audioUrl           String?  @db.Text

  deckId          String
  deck            Deck          @relation(fields: [deckId], references: [id], onDelete: Cascade)

  schedule        CardSchedule?
  reviewLogs      ReviewLog[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([deckId])
  @@index([cardType])
  // Database-level dedup (Phase 21A). Replaces app-level check-then-insert.
  // Vocabulary/sentence: one (deck, type, question). Grammar: one (deck, type,
  // patternId) — patternId is NULL for non-grammar so those rows never collide
  // here (NULLs are distinct in Postgres).
  @@unique([deckId, cardType, question])
  @@unique([deckId, cardType, patternId])
  @@index([updatedAt])
  @@map("cards")
}

model CardSchedule {
  id           String   @id @default(cuid())

  cardId       String   @unique
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  dueDate      DateTime @default(now())
  lastReviewAt DateTime?

  stability    Float    @default(0)
  difficulty   Float    @default(5)
  reps         Int      @default(0)
  lapses       Int      @default(0)
  state        String   @default("new")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([dueDate])
  @@index([cardId])
  @@map("card_schedules")
}

model ReviewLog {
  id         String   @id @default(cuid())

  cardId     String
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  rating     Int
  duration   Int

  // Client-supplied idempotency key (Phase 21B). Unique so a retried/offline
  // batch never double-applies a review. Null for legacy single submits.
  clientReviewId String? @unique

  reviewedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([cardId])
  @@index([reviewedAt])
  @@index([createdAt])
  @@map("review_logs")
}

model DictionaryEntry {
  id           String   @id @default(cuid())

  word         String
  reading      String?
  meanings     String[] @default([])
  jlptLevel    String?
  frequency    Int?
  partOfSpeech String?
  pitchAccent  String?
  priority     Int?
  commonWord   Boolean  @default(false)
  source       String   @default("jmdict")

  createdAt    DateTime @default(now())

  @@unique([word, reading])
  @@index([word])
  @@index([reading])
  @@index([jlptLevel])
  @@index([commonWord])
  @@index([frequency])
  @@index([commonWord, frequency])
  @@map("dictionary_entries")
}

// AI lookup cache (Phase 26A). Persistent (no TTL). Keyed by normalizedQuery +
// kind ("word"|"sentence") so repeated/inflected lookups avoid AI calls. `kind`
// is an addition beyond the spec's field list to disambiguate word vs sentence
// entries that could share a normalized form.
model AiDictionaryEntry {
  id              String   @id @default(cuid())

  query           String
  normalizedQuery String
  kind            String   @default("word") // "word" | "sentence"

  reading         String?
  meaning         String?
  examples        String[] @default([])
  jlptLevel       String?
  pitchAccent     String?

  provider        String
  hitCount        Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUsedAt      DateTime @default(now())

  @@unique([normalizedQuery, kind])
  @@index([provider])
  @@index([hitCount])
  @@map("ai_dictionary_entries")
}

// AI usage counter (Phase 26A premium prep). One row per (userId, date);
// userId is "anonymous" for unauthenticated lookups. Records cache MISSES
// (provider calls) only — cache hits never increment. No enforcement yet.
model AiUsage {
  id           String   @id @default(cuid())

  userId       String   // "anonymous" when unauthenticated
  date         String   // YYYY-MM-DD (UTC)
  requestCount Int      @default(0)

  createdAt    DateTime @default(now())

  @@unique([userId, date])
  @@index([date])
  @@map("ai_usage")
}
