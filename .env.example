NODE_ENV=development
PORT=3000

# Database (for docker-compose: postgresql://jap_user:jap_password@localhost:5432/jap_db)
DATABASE_URL=postgresql://user:password@localhost:5432/jap_db

# JWT
JWT_SECRET=your-secret-key-here-minimum-32-characters-required
JWT_EXPIRE=7d

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3001
